# Ignore everything by default
*

# Un-ignore Project_Delivery and its contents
!Project_Delivery/
!Project_Delivery/**

# Exclude large processed data files within Project_Delivery
Project_Delivery/data/processed_data/*.h5ad
Project_Delivery/data/processed_data/*.h5
Project_Delivery/data/processed_data/*.hdf5

# Exclude PDF reports (Chinese content, replaced by README)
Project_Delivery/report_phase*.pdf

# Un-ignore README and gitignore themselves
!README.md
!.gitignore

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/
~$*
